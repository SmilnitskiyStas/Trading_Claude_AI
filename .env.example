# ── EXCHANGES ─────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET=your_binance_secret

BYBIT_API_KEY=your_bybit_api_key
BYBIT_SECRET=your_bybit_secret

KRAKEN_API_KEY=your_key
KRAKEN_SECRET=your_secret

OKX_API_KEY=your_key
OKX_SECRET=your_secret
OKX_PASSPHRASE=your_passphrase

# ── ACTIVE EXCHANGES ───────────────────────────────────────────────────────
ACTIVE_EXCHANGES=binance,bybit
PRIMARY_EXCHANGE=binance

# ── NEWS ──────────────────────────────────────────────────────────────────
CRYPTOPANIC_API_KEY=your_key

# ── AI AGENT ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_key

# ── TELEGRAM ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── DATABASE ──────────────────────────────────────────────────────────────
# On VPS (Docker internal network — use service name "postgres"):
DATABASE_URL=postgresql://trader:trading_pass@postgres:5432/trading
POSTGRES_PASSWORD=trading_pass

# ── REDIS ─────────────────────────────────────────────────────────────────
# On VPS (Docker internal network — use service name "redis"):
REDIS_URL=redis://redis:6379
REDIS_DB=0

# ── TRADING ───────────────────────────────────────────────────────────────
PAPER_TRADING=true
INITIAL_BALANCE=10000
MAX_POSITION_SIZE=0.10
STOP_LOSS=0.03
TAKE_PROFIT=0.06
MAX_DAILY_LOSS=0.05

# ── MONITORING ────────────────────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
LOG_LEVEL=INFO
